# SolAgent Local Configuration
# This file is gitignored. Put your real keys and wallet here.
# Copy from config/default.toml and override.

[agent]
name = "solagent"
poll_interval_secs = 30
log_level = "info"

[chains]
[chains.solana]
rpc_urls = ["https://api.mainnet-beta.solana.com"]
ws_url = "wss://api.mainnet-beta.solana.com"
helius_api_key = ""  # Set HELIUS_API_KEY env var instead, or paste here
private_key_bs58 = ""  # Your trading wallet private key in base58 (or use config/trading-wallet.json)

[risk]
max_position_size_usd = 15.0
max_portfolio_risk_pct = 25.0
max_daily_loss_usd = 15.0
max_drawdown_pct = 15.0
max_open_positions = 3
default_stop_loss_pct = 15.0
default_take_profit_pct = 40.0
cooldown_secs = 300
safety_score_threshold = 70

[strategies]
active_strategies = ["whale_consensus", "accumulation", "launch_momentum", "volume_spike", "social"]
confluence_threshold = 65.0
min_signal_count = 2

[data]
jupiter_api_url = "https://quote-api.jup.ag/v6"
dexscreener_base_url = "https://api.dexscreener.com"
birdeye_base_url = "https://public-api.birdeye.so"

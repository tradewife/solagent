# SolAgent Environment Variables
# Copy to .env and fill in your values.

# Birdeye API Key (required for safety scoring + token analysis)
# Get free key at: https://bds.birdeye.so/
BIRDEYE_API_KEY=

# Helius API Key (optional, improves wallet monitoring + faster RPC)
# Get free key at: https://dev.helius.xyz/
HELIUS_API_KEY=

# Solana private key (base58 encoded) -- ALSO set in config/local.toml
# This is for reference; the agent reads from config/local.toml
# SOLANA_PRIVATE_KEY=
